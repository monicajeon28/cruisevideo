# CruiseDot Video Pipeline - 환경 변수 템플릿
# 이 파일을 복사하여 .env 파일을 만들고 실제 값을 입력하세요.
# Windows: copy .env.example .env
# Linux/Mac: cp .env.example .env

# ==================== AI 모델 API ====================

# Gemini API Key (콘텐츠 생성) - 유료 Pay-as-you-go
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Replicate - Flux.1 (이미지 생성)
# 발급: https://replicate.com/account/api-tokens
FLUX_API_KEY=your_flux_api_key_here

# Kie AI / Hailuo (영상 생성)
KIE_API_KEY=your_kie_api_key_here

# YouTube Data API v3
# 발급: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# YouTube OAuth 2.0 (Analytics API 용)
YOUTUBE_OAUTH_CLIENT_ID=your_client_id_here
YOUTUBE_OAUTH_CLIENT_SECRET=your_client_secret_here

# OpenAI API Key (GPT-4o Mini - 썸네일, 보조)
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (Claude - 누끼 파일명 자동 생성)
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude API Key (alias for ANTHROPIC_API_KEY)
CLAUDE_API_KEY=your_anthropic_api_key_here

# ==================== 음성/음악/비디오 생성 API ====================

# ElevenLabs API Key (음성 생성)
# 발급: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Suno API Key (음악 생성)
SUNO_API_KEY=your_suno_api_key_here

# Runway API Key (비디오 생성)
RUNWAY_API_KEY=your_runway_api_key_here

# Supertone API Key (한국어 TTS - 감정 표현 풍부)
# 발급: https://supertone.ai (로그인 후 Dashboard)
SUPERTONE_API_KEY=your_supertone_api_key_here

# ==================== 미디어 소스 API ====================

# Pexels API Key (영상 소스) - 무료, 200 req/hour, 20K req/month
# 발급: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Unsplash API Key (이미지 소스) - 무료, 50 req/hour
# 발급: https://unsplash.com/developers
UNSPLASH_API_KEY=your_unsplash_api_key_here

# Pixabay API Key (이미지 + 영상 + BGM) - 무료, 무제한
# 발급: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_api_key_here

# Freesound API Key (효과음) - 무료, 60 req/min
# 발급: https://freesound.org/apiv2/apply/
FREESOUND_API_KEY=your_freesound_api_key_here

# Stability AI API Key (AI 이미지 생성) - 유료
# 발급: https://platform.stability.ai/
STABILITY_API_KEY=your_stability_api_key_here

# ==================== ElevenLabs 음성 ID ====================

# 30대 아나운서형 여성
VOICE_ID_FEMALE_30_ANNOUNCER=your_voice_id_here

# 30대 크리에이티브형 여성
VOICE_ID_FEMALE_30_CREATIVE=your_voice_id_here

# 30대 차분한 범준 남성
VOICE_ID_MALE_30_CALM=your_voice_id_here

# 40대 중년 여성
VOICE_ID_FEMALE_40=your_voice_id_here

# 30대 마이크 남성
VOICE_ID_MALE_30_MIKE=your_voice_id_here

# 30대 남성 태오
VOICE_ID_MALE_30_TAEO=your_voice_id_here

# 30대 여성 한 대화형
VOICE_ID_FEMALE_30_HAN=your_voice_id_here

# 50대 장뎀보 남성
VOICE_ID_MALE_50_JANG=your_voice_id_here

# 30대 남성 카일
VOICE_ID_MALE_30_KYLE=your_voice_id_here

# ==================== Supertone 음성 ID (감정 표현 풍부) ====================

# 40대 여성 Grace (Game, Storytelling, Acting)
SUPERTONE_VOICE_GRACE=your_voice_id_here

# 30대 남성 Flop (Game, Short-Form, Entertainment, Meme, Humor)
SUPERTONE_VOICE_FLOP=your_voice_id_here

# 40대 남성 Juho (Conversational, Acting, Business, Short-Form, Review, Storytelling)
SUPERTONE_VOICE_JUHO=your_voice_id_here

# 60대 남성 Osman (Game, Audiobook, Storytelling, Acting)
SUPERTONE_VOICE_OSMAN=your_voice_id_here

# 30대 Ppang BuJang - 맛집 컨텐츠 추천
SUPERTONE_VOICE_PPANG=your_voice_id_here

# 30대 Sangchul (Entertainment, Meme, Conversational, Short-Form, Review, Parody)
SUPERTONE_VOICE_SANGCHUL=your_voice_id_here

# 10대 어린이 Billy (Meme, Conversational, Acting, Storytelling, Game)
SUPERTONE_VOICE_BILLY=your_voice_id_here

# 40대 남성 Yannom - 레저 테마 추천
SUPERTONE_VOICE_YANNOM=your_voice_id_here

# 30대 여성 Ariel (Meme, Conversational, Acting, Entertainment, Storytelling, Short-Form, Review)
SUPERTONE_VOICE_ARIEL=your_voice_id_here

# 30대 여성 Audrey - 아나운서형
SUPERTONE_VOICE_AUDREY=your_voice_id_here

# 50대 남성 Bert (Game, Storytelling, Acting)
SUPERTONE_VOICE_BERT=your_voice_id_here

# 40대 여성 Dakota (Game, Conversational, Acting, Storytelling)
SUPERTONE_VOICE_DAKOTA=your_voice_id_here

# 30대 남성 Dudumchi (Game, Acting, Storytelling, Entertainment, Humor, Short-Form, Meme, Advertisement)
SUPERTONE_VOICE_DUDUMCHI=your_voice_id_here

# 기본 선택 음성 (30대 아나운서형 여성)
SELECTED_VOICE_ID=your_default_voice_id_here

# ==================== 로컬 리소스 경로 ====================

# 크루즈 영상 파일
LOCAL_FOOTAGE_DIR=D:\\AntiGravity\\Assets\\Footage

# 크루즈 이미지 파일
LOCAL_IMAGE_DIR=D:\\AntiGravity\\Assets\\Image

# BGM 파일
LOCAL_MUSIC_DIR=D:\\AntiGravity\\Assets\\Music

# BGM 백업 + 키워드 정보
LOCAL_MUSIC_BACKUP_DIR=D:\\AntiGravity\\Assets\\Music_Backup

# 누끼 파일
LOCAL_CUTOUT_DIR=D:\\AntiGravity\\Assets

# 로고 파일
LOCAL_LOGO_PATH=D:\\AntiGravity\\Assets\\Image\\로고

# 효과음
LOCAL_SFX_DIR=D:\\AntiGravity\\Assets\\SoundFX

# 인트로 효과음
INTRO_SFX_PATH=D:\\AntiGravity\\Assets\\SoundFX\\level-up-08-402152

# 아웃트로 효과음
OUTRO_SFX_PATH=D:\\AntiGravity\\Assets\\SoundFX\\ship-horn-352063

# ==================== 데이터 경로 ====================

# 학습 데이터 입력
INPUT_DIR=D:\\AntiGravity\\INPUT

# 학습 데이터 저장
LEARNING_DIR=D:\\AntiGravity\\LEARNING

# 데이터 수집
DATA_COLLECTION_DIR=D:\\AntiGravity\\DataCollection

# 최종 결과물 출력
OUTPUT_DIR=D:\\AntiGravity\\Output

# ==================== Validation API 인증 ====================

# Validation API 키 (보안 필수 - 운영환경에서는 반드시 변경)
VALIDATION_API_KEY=your_validation_api_key_here

# ==================== YouTube API OAuth ====================

# YouTube OAuth 2.0 Credentials
YOUTUBE_CREDENTIALS_PATH=D:/mabiz/config/credentials.json
YOUTUBE_TOKEN_PATH=D:/mabiz/config/token.pickle

# YouTube API 설정
YOUTUBE_API_QUOTA_DAILY=10000
YOUTUBE_CHANNEL_ID=  # 실제 채널 ID로 변경 (예: UCxxxxxxxxxxxxxxx)

# ==================== 영상 생성 API ====================

# Runware API Key (Hailuo 2.3 Fast - Image to Video)
RUNWARE_API_KEY=your_runware_api_key_here

# Vidu API Key (Vidu 2.0 - Image to Video)
VIDU_API_KEY=your_vidu_api_key_here

# Environment setting (development/production)
ENVIRONMENT=development

# ==================== Neon PostgreSQL (cruisedot.co.kr 상품 DB) ====================

# Neon DB 연결 정보 (ap-southeast-2)
DATABASE_URL_TEST=postgresql://user:password@host:port/database?sslmode=require
