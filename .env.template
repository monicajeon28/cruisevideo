# =============================================================================
# 크루즈 콘텐츠 자동화 S등급 시스템 - API 키 설정
# =============================================================================
# 이 파일을 .env로 복사하고 실제 API 키를 입력하세요
# 명령: cp .env.template .env
# =============================================================================

# Claude Sonnet 4.5 API 키 (스크립트 생성용)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-api-key-here

# OpenAI GPT-4o API 키 (SEO 메타데이터 생성용)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-api-key-here

# Google Gemini 2.0 Flash API 키 (Shorts 추출용)
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# ElevenLabs API 키 (나레이션 음성 생성용 - 선택사항)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# =============================================================================
# 비용 최적화 설정
# =============================================================================

# 최대 토큰 사용량 (안전장치)
MAX_TOKENS_SCRIPT=8000
MAX_TOKENS_SEO=2000
MAX_TOKENS_SHORTS=4000

# 병렬 처리 동시 실행 수
MAX_PARALLEL_AGENTS=5

# =============================================================================
# 프로젝트 설정
# =============================================================================

# 출력 디렉토리
OUTPUT_DIR=./output

# 로컬 자산 베이스 디렉토리
ASSETS_BASE=./assets

# 학습 데이터 디렉토리
LEARNING_DATA=./learning_data/gemini_research
