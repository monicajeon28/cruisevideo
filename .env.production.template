# ===================================================================
# MaBiz Production Environment Configuration Template
# ===================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to git!

# ===== Required API Keys =====

# Google Gemini API (REQUIRED for script generation)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API (Optional - for Monica Booster)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ===== Optional API Keys =====

# Pexels API (for stock images/videos)
# Get from: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key-here

# ViewTrap API (for trend analysis)
VIEWTRAP_API_KEY=your-viewtrap-api-key-here

# Reddit API (for community trends)
# Create app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=MabizTrendAnalyzer/1.0

# ===== Server Configuration =====

# Environment mode
ENVIRONMENT=production

# API Server settings
API_HOST=0.0.0.0
API_PORT=8000

# CORS Configuration (comma-separated domains)
FRONTEND_URL=https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===== Video Generation Settings =====

# FFmpeg path (leave as 'ffmpeg' if in PATH)
FFMPEG_PATH=ffmpeg

# Output directory for generated videos
OUTPUT_DIR=./output

# Maximum video duration (seconds)
MAX_VIDEO_DURATION=300

# Video generation timeout (seconds)
VIDEO_GENERATION_TIMEOUT=300

# Maximum concurrent jobs
MAX_CONCURRENT_JOBS=4

# ===== Storage Configuration =====

# Auto-cleanup old videos (days)
CLEANUP_AFTER_DAYS=7

# Maximum storage size (GB)
MAX_STORAGE_GB=100

# ===== Logging Configuration =====

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/app.log

# Log rotation size (MB)
LOG_MAX_SIZE_MB=10

# Number of backup log files
LOG_BACKUP_COUNT=10

# ===== Security Settings =====

# API rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# Maximum upload file size (MB)
MAX_UPLOAD_SIZE_MB=100

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.mp3,.wav,.mp4

# ===== Optional: Google Sheets Backup =====

# Google Spreadsheet ID for data backup
# Get from spreadsheet URL: https://docs.google.com/spreadsheets/d/YOUR_ID/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# ===== Optional: Analytics =====

# Google Analytics tracking ID
GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry DSN for error tracking
SENTRY_DSN=https://your-sentry-dsn-here

# ===== Optional: Email Notifications =====

# SMTP server for email alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# Alert email recipients (comma-separated)
ALERT_EMAILS=admin@yourdomain.com,devops@yourdomain.com

# ===== Database Configuration (if needed) =====

# PostgreSQL connection string (optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/mabiz

# Redis URL for caching (optional)
# REDIS_URL=redis://localhost:6379/0

# ===== End of Configuration =====
